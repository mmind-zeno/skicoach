{
  "name": "webapp",
  "version": "0.9.5",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server.ts",
    "build": "next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:apply": "node node_modules/tsx/dist/cli.mjs scripts/apply-sql-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:test": "node node_modules/tsx/dist/cli.mjs scripts/test-db.ts",
    "check:api-errors": "node node_modules/tsx/dist/cli.mjs scripts/check-api-error.ts",
    "check:ui-errors": "node node_modules/tsx/dist/cli.mjs scripts/check-client-error-message.ts",
    "check:migration-journal": "node node_modules/tsx/dist/cli.mjs scripts/check-migration-journal.ts",
    "db:seed": "node node_modules/tsx/dist/cli.mjs scripts/seed.ts",
    "db:seed:demo-crm": "node node_modules/tsx/dist/cli.mjs scripts/seed-demo-crm-guests.ts",
    "db:baseline-legacy": "node node_modules/tsx/dist/cli.mjs scripts/drizzle-baseline-legacy.ts",
    "smoke:critical-paths": "node node_modules/tsx/dist/cli.mjs scripts/smoke-critical-paths.ts",
    "admin:login-url": "node node_modules/tsx/dist/cli.mjs scripts/issue-admin-login.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@react-pdf/renderer": "^4.3.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "next": "14.2.18",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "^18",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1",
    "tsx": "^4.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^18",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
