# .env.example — skicoach (Repo-Root, neben docker-compose.yml)
# Kopie: webapp/.env.local (lokal) / .env hier (Server). Niemals committen.

# ── App / Domain ─────────────────────────────────────────────────────────────
# DNS: skicoach.mmind.space → 49.13.139.206
DOMAIN=skicoach.mmind.space
NEXTAUTH_URL=https://skicoach.mmind.space
NEXT_PUBLIC_APP_URL=https://skicoach.mmind.space

# Optional: Marke & Texte ohne Codeänderung (siehe FORKING.md, webapp/src/config/brand.ts)
# NEXT_PUBLIC_SITE_NAME=skicoach
# NEXT_PUBLIC_SITE_DOMAIN=skicoach.li
# Demo-Seed & Admin-Bootstrap (npm run db:seed, npm run admin:login-url): E-Mail-Domain für admin@ / lehrer{n}@
# SEED_EMAIL_DOMAIN=skicoach.li
# SEED_ADMIN_EMAIL=admin@skicoach.li
# ADMIN_BOOTSTRAP_EMAIL=admin@skicoach.li
# ADMIN_BOOTSTRAP_NAME=Admin
# NEXT_PUBLIC_SUPPORT_EMAIL=info@skicoach.li
# NEXT_PUBLIC_MARKETING_TAGLINE=Skischule — interne Verwaltung & Buchungsportal
# NEXT_PUBLIC_HOME_LEAD=Buchungsportal und Team-Workspace …
# NEXT_PUBLIC_HTML_LANG=de
# NEXT_PUBLIC_ISSUER_LOCATION=Liechtenstein
# Mehrzeilige postalische Anschrift für Datenschutz & Impressum (Zeilenumbrüche: \n in der Zeichenkette)
# NEXT_PUBLIC_LEGAL_POSTAL_ADDRESS=Musterfirma AG\nMusterstrasse 1\n9490 Vaduz
# NEXT_PUBLIC_SERVICE_SLUG=skicoach-webapp
# Feature-Flags (false | 0 | off schaltet ab; leer = wie Default in webapp/src/lib/features.ts)
# NEXT_PUBLIC_FEATURE_PUBLIC_BOOKING=true
# NEXT_PUBLIC_FEATURE_INVOICES=true
# NEXT_PUBLIC_FEATURE_CHAT=true
# NEXT_PUBLIC_FEATURE_PAYMENTS=false
# NEXT_PUBLIC_FEATURE_WEBHOOKS=false
# NEXT_PUBLIC_FEATURE_ICAL=true
# Startseiten-Pilot „Atmospheric Ascent“ (nur /): Dev standardmäßig AN (außer false).
# Docker-Compose Build-Default: true (siehe docker-compose.yml). Zum Deaktivieren auf dem Server:
# NEXT_PUBLIC_LANDING_PILOT=false
# iCal-Feed (HMAC-Token); setzen wenn /api/calendar/ical genutzt wird (Fallback: AUTH_SECRET)
# ICAL_FEED_SECRET=
# Optional: Build-Version / Git für Health-JSON (Support); Docker-Build-Arg in docker-compose
# NEXT_PUBLIC_APP_VERSION=0.9.4
# NEXT_PUBLIC_GIT_SHA=
# GIT_COMMIT=
# NEXT_PUBLIC_LOGIN_HERO_GRADIENT_FROM=#0c1f3a
# NEXT_PUBLIC_LOGIN_HERO_GRADIENT_VIA=#1B4F8A
# NEXT_PUBLIC_LOGIN_HERO_GRADIENT_TO=#4a90c4

# Hinter Caddy: Host-Header und Forwarded-Proto vertrauen
AUTH_TRUST_HOST=true

# Zufällig: openssl rand -base64 32
NEXTAUTH_SECRET=HIER_ZUFAELLIGEN_STRING_EINSETZEN

ADMIN_NOTIFICATION_EMAIL=admin@skicoach.li

# Muss zu caddy-skicoach.caddyfile passen (ss -tlnp auf dem Server prüfen)
HOST_APP_PORT=3002

TZ=Europe/Zurich

# ── Datenbank ────────────────────────────────────────────────────────────────
DB_NAME=skicoach
DB_USER=skicoach_user
DB_PASSWORD=SICHERES_PASSWORT_EINSETZEN

# Lokal (ohne Docker): localhost. Im Compose: wird durch DATABASE_URL im app-Container ersetzt.
DATABASE_URL=postgresql://skicoach_user:SICHERES_PASSWORT@localhost:5432/skicoach
# Optional: drizzle-kit CLI, falls DATABASE_URL nicht gesetzt (selten)
# DRIZZLE_DATABASE_URL=postgresql://skicoach_user:SICHERES_PASSWORT@localhost:5432/skicoach

# ── E-Mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_HIER_API_KEY_EINSETZEN
RESEND_FROM_EMAIL=noreply@skicoach.li

# ── Cloudflare Turnstile (optional, öffentliche Buchung /buchen) ────────────
# Beide setzen, sonst blockiert die API ohne Widget. Ohne Secret: keine Prüfung.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# ── Wartung öffentliches Buchungsportal ───────────────────────────────────────
# true | 1 | yes | on — leitet /buchen → /wartung, öffentliche APIs (ausser Health) → 503
# MAINTENANCE_MODE=

# ── Gäste-Portal (Meine Termine) & Termin-Erinnerungen ───────────────────────
# JWT für /buchen/meine-termine — Fallback: NEXTAUTH_SECRET / AUTH_SECRET
# GUEST_PORTAL_SECRET=
# Storno durch Gast: Mindest-Stunden vor Termin (Default 24)
# GUEST_CANCEL_MIN_HOURS_BEFORE=24
# Erinnerungs-Mail (Resend): Intervall im Server (ms), Stunden vor Termin, Fenster für Poll-Takt
# REMINDER_POLL_INTERVAL_MS=900000
# REMINDER_HOURS_BEFORE=24
# REMINDER_WINDOW_HOURS=0.75
# REMINDER_EMAIL_ENABLED=true
# Optional: SMS/Webhook (POST JSON { to, text }) — z. B. Twilio-Bridge
# REMINDER_SMS_WEBHOOK_URL=

# ── Rechnungs-PDF (optional) ─────────────────────────────────────────────────
BANK_NAME=
BANK_IBAN=
BANK_ADDRESS=

# ── SSL (nur docker-compose.traefik.yml) ────────────────────────────────────
ACME_EMAIL=admin@skicoach.li

# ── Phase 2: Stripe ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Lokal webapp ────────────────────────────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
