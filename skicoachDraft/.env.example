# .env.example — skicoach
# Kopie: .env.local (lokal) / .env (Server). Niemals committen.

# ── App / Domain ─────────────────────────────────────────────────────────────
DOMAIN=skicoach.mmind.space
NEXTAUTH_URL=https://skicoach.mmind.space
NEXT_PUBLIC_APP_URL=https://skicoach.mmind.space

# Hinter Caddy/Nginx: Host-Header und Forwarded-Proto vertrauen
AUTH_TRUST_HOST=true

# Zufällig: openssl rand -base64 32
NEXTAUTH_SECRET=HIER_ZUFAELLIGEN_STRING_EINSETZEN

# Öffentliches Buchungsportal: Admin-Benachrichtigung (Magic Link / Anfragen)
ADMIN_NOTIFICATION_EMAIL=admin@skicoach.li

# Docker: App nur auf 127.0.0.1 (Caddy reverse_proxy auf diesem Port). Muss zu
# caddy-skicoach.caddyfile passen. Auf dem Server vorher: ss -tlnp (Konflikt mit n8n vermeiden).
HOST_APP_PORT=3002

# Kalender / DB-Zeit (Container + App)
TZ=Europe/Zurich

# ── Datenbank ────────────────────────────────────────────────────────────────
DB_NAME=skicoach
DB_USER=skicoach_user
DB_PASSWORD=SICHERES_PASSWORT_EINSETZEN

DATABASE_URL=postgresql://skicoach_user:SICHERES_PASSWORT@localhost:5432/skicoach

# ── E-Mail (Resend) ──────────────────────────────────────────────────────────
# Domain in Resend verifizieren (z. B. email.mmind.space); Absender @ dieser Domain.
RESEND_API_KEY=re_HIER_API_KEY_EINSETZEN
RESEND_FROM_EMAIL=noreply@email.mmind.space

# ── SSL (nur bei docker-compose.traefik.yml) ────────────────────────────────
ACME_EMAIL=admin@skicoach.li

# ── Phase 2: Stripe ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Lokal ───────────────────────────────────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# DATABASE_URL=postgresql://skicoach_user:password@localhost:5432/skicoach
